{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-ext"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-ext/dist/**/*.js"
      ],
      "preLaunchTask": "compile: vscode-ext"
    }
  ]
}
