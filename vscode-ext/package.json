{
  "name": "vscode-pi-sr",
  "displayName": "Pi Agent Companion",
  "description": "Review and approve file changes proposed by Pi agent. Also controllable from the terminal TUI (Approve, Reject, Rethink, Approve All, Abort) — both interfaces work in parallel.",
  "version": "1.4.7",
  "publisher": "Serhioromano",
  "icon": "icon.png",
  "license": "MIT",
  "repository": "github:Serhioromano/pi-vscode-sr",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/vscode-ext/src/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "pi-sr.chat",
        "name": "pi",
        "fullName": "Pi Agent",
        "description": "Ask Pi to code, review files, run commands",
        "isSticky": true
      }
    ],
    "commands": [
      {
        "command": "pi-sr.approveCurrent",
        "title": "Pi SR: Accept",
        "icon": "$(check)"
      },
      {
        "command": "pi-sr.rejectCurrent",
        "title": "Pi SR: Reject",
        "icon": "$(close)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "pi-sr.approveCurrent",
          "when": "piSr.isActive",
          "group": "navigation@1"
        },
        {
          "command": "pi-sr.rejectCurrent",
          "when": "piSr.isActive",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Pi Agent",
      "properties": {
        "pi.chat.toolVisibility": {
          "type": "string",
          "default": "verbose",
          "enum": ["verbose", "quiet"],
          "description": "Controls tool execution display in Pi chat responses. Verbose shows collapsible sections with tool details; quiet shows only 'Pi is working...' progress."
        },
        "pi.chat.interruptionBehavior": {
          "type": "string",
          "default": "abort",
          "enum": ["abort", "followUp"],
          "description": "Controls behavior when a new message is sent while Pi is still streaming. Abort cancels the current response; followUp queues the message to process after the current response completes."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.82.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.8"
  }
}
